# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Database
DATABASE_URL=postgresql://...

# Email (Resend)
RESEND_API_KEY=re_...
# Sender address for all outbound email. Must be on a domain verified in Resend
# (SPF/DKIM configured). Use a bare address — display names like
# "Lonestar Tortillas <...>" are added in code where needed.
RESEND_FROM_EMAIL=howdy@lonestartortillas.com

# Admin
ADMIN_TOKEN=your-secure-admin-token

# Feature Toggles
ALLOW_REFRIGERATED=false

# App Configuration
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Analytics & Tracking
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Google Ads (optional) — metrics dashboard + offline conversion import.
# All five below are required for any Google Ads feature to activate.
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
# Customer ID of the ad account (with or without dashes), e.g. 123-456-7890
GOOGLE_ADS_CUSTOMER_ID=
# Manager (MCC) account ID — only needed when accessing the account via an MCC
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# Numeric conversion action ID for the server-side offline conversion import.
# Found in Google Ads UI (Goals > Conversions); the action must be created with
# source = "Import" / API and be enabled. We build the resource name as
# customers/<GOOGLE_ADS_CUSTOMER_ID>/conversionActions/<this id>.
GOOGLE_ADS_CONVERSION_ACTION_ID=

# OpenRouter API (Image Generation)
# Get your API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here